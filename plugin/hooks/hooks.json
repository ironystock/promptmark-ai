{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/session-start.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__promptmark__update_prompt|mcp__promptmark__create_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/post-prompt-edit.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__promptmark__update_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/pre-publish-gate.sh"
          }
        ]
      }
    ]
  }
}
